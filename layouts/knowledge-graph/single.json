{{- $scratch := newScratch -}}
{{- $scratch.Set "nodes" (slice) -}}
{{- $scratch.Set "pages" (slice) -}}
{{- $scratch.Set "edges" (slice) -}}
{{- $scratch.Set "edgeSeen" (dict) -}}
{{- $scratch.Set "degree" (dict) -}}
{{- $scratch.Set "nodeById" (dict) -}}
{{- $scratch.Set "urlToId" (dict) -}}
{{- $scratch.Set "dayToId" (dict) -}}
{{- $scratch.Set "topicLast" (dict) -}}
{{- $scratch.Set "topicCounts" (dict) -}}
{{- $scratch.Set "topicOverrideMap" (dict) -}}
{{- $scratch.Set "aliasMap" (dict) -}}
{{- $scratch.Set "removeEdgeMap" (dict) -}}

{{- $overrides := .Site.Data.java_graph_overrides -}}

{{- with $overrides.topicOverrides -}}
  {{- range . -}}
    {{- $nodeID := trim (printf "%v" .nodeId) " " -}}
    {{- $topic := trim (printf "%v" .topic) " " -}}
    {{- if and (ne $nodeID "") (ne $topic "") -}}
      {{- $scratch.SetInMap "topicOverrideMap" $nodeID $topic -}}
    {{- end -}}
  {{- end -}}
{{- end -}}

{{- with $overrides.aliases -}}
  {{- range . -}}
    {{- $fromRaw := partial "java_graph/normalize_link.html" (dict "link" .from) -}}
    {{- $toRaw := partial "java_graph/normalize_link.html" (dict "link" .to) -}}
    {{- $from := trim (printf "%s" $fromRaw) " " -}}
    {{- $to := trim (printf "%s" $toRaw) " " -}}
    {{- if and (gt (len $from) 0) (gt (len $to) 0) -}}
      {{- $scratch.SetInMap "aliasMap" $from $to -}}
    {{- end -}}
  {{- end -}}
{{- end -}}

{{- with $overrides.removeEdges -}}
  {{- range . -}}
    {{- $source := trim (printf "%v" .source) " " -}}
    {{- $target := trim (printf "%v" .target) " " -}}
    {{- $type := trim (printf "%v" .type) " " -}}
    {{- if and (ne $source "") (ne $target "") (ne $type "") -}}
      {{- $scratch.SetInMap "removeEdgeMap" (printf "%s|%s|%s" $source $target $type) true -}}
    {{- end -}}
  {{- end -}}
{{- end -}}

{{- $allPosts := where .Site.RegularPages "Type" "posts" -}}
{{- range $post := $allPosts -}}
  {{- $slug := lower (printf "%v" $post.Params.slug) -}}
  {{- $path := lower $post.RelPermalink -}}
  {{- $categoryProbe := lower (printf "%v" $post.Params.category) -}}
  {{- $categoriesProbe := lower (printf "%v" $post.Params.categories) -}}
  {{- if or (in $slug "100daysofjava") (in $path "100daysofjava") (in $categoryProbe "100daysofjava") (in $categoriesProbe "100daysofjava") -}}
    {{- $idRaw := partial "java_graph/node_id.html" (dict "page" $post) -}}
    {{- $id := trim (printf "%s" $idRaw) " " -}}

    {{- $categories := slice -}}
    {{- with $post.Params.category -}}
      {{- $categoryType := printf "%T" . -}}
      {{- if or (eq $categoryType "[]string") (eq $categoryType "[]interface {}") -}}
        {{- range . -}}
          {{- $value := trim (printf "%v" .) " " -}}
          {{- if and (ne $value "") (ne $value "[]") -}}
            {{- $categories = append $value $categories -}}
          {{- end -}}
        {{- end -}}
      {{- else -}}
        {{- $value := trim (printf "%v" .) " " -}}
        {{- if and (ne $value "") (ne $value "[]") -}}
          {{- $categories = append $value $categories -}}
        {{- end -}}
      {{- end -}}
    {{- end -}}
    {{- with $post.Params.categories -}}
      {{- $categoryType := printf "%T" . -}}
      {{- if or (eq $categoryType "[]string") (eq $categoryType "[]interface {}") -}}
        {{- range . -}}
          {{- $value := trim (printf "%v" .) " " -}}
          {{- if and (ne $value "") (ne $value "[]") -}}
            {{- $categories = append $value $categories -}}
          {{- end -}}
        {{- end -}}
      {{- else -}}
        {{- $value := trim (printf "%v" .) " " -}}
        {{- if and (ne $value "") (ne $value "[]") -}}
          {{- $categories = append $value $categories -}}
        {{- end -}}
      {{- end -}}
    {{- end -}}

    {{- $summary := trim ($post.Summary | plainify | htmlUnescape) " " -}}
    {{- if eq $summary "" -}}
      {{- $summary = truncate 240 ($post.Plain | plainify | htmlUnescape) -}}
    {{- end -}}

    {{- $day := 0 -}}
    {{- $dayProbe := printf "%s %s %s" $post.Title (printf "%v" $post.Params.slug) $post.File.BaseFileName -}}
    {{- $dayToken := findRE `(?i)day[-:\s]*[0-9]{1,3}` $dayProbe 1 -}}
    {{- if gt (len $dayToken) 0 -}}
      {{- $dayDigits := replaceRE `\D` "" (index $dayToken 0) -}}
      {{- if ne $dayDigits "" -}}
        {{- $day = int $dayDigits -}}
      {{- end -}}
    {{- end -}}

    {{- $explicitTopics := slice -}}
    {{- with $post.Params.topic -}}
      {{- $topicType := printf "%T" . -}}
      {{- if or (eq $topicType "[]string") (eq $topicType "[]interface {}") -}}
        {{- range . -}}
          {{- $value := trim (printf "%v" .) " " -}}
          {{- if ne $value "" -}}
            {{- $explicitTopics = append $value $explicitTopics -}}
          {{- end -}}
        {{- end -}}
      {{- else -}}
        {{- $value := trim (printf "%v" .) " " -}}
        {{- if ne $value "" -}}
          {{- $explicitTopics = append $value $explicitTopics -}}
        {{- end -}}
      {{- end -}}
    {{- end -}}
    {{- with $post.Params.topics -}}
      {{- $topicType := printf "%T" . -}}
      {{- if or (eq $topicType "[]string") (eq $topicType "[]interface {}") -}}
        {{- range . -}}
          {{- $value := trim (printf "%v" .) " " -}}
          {{- if ne $value "" -}}
            {{- $explicitTopics = append $value $explicitTopics -}}
          {{- end -}}
        {{- end -}}
      {{- else -}}
        {{- $value := trim (printf "%v" .) " " -}}
        {{- if ne $value "" -}}
          {{- $explicitTopics = append $value $explicitTopics -}}
        {{- end -}}
      {{- end -}}
    {{- end -}}

    {{- $topicRaw := partial "java_graph/classify_topic" (dict "title" $post.Title "summary" $summary "content" $post.Plain "categories" $categories "topics" $explicitTopics) -}}
    {{- $topic := trim (printf "%s" $topicRaw) " " -}}
    {{- with index ($scratch.Get "topicOverrideMap") $id -}}
      {{- $topic = . -}}
    {{- end -}}

    {{- $node := dict
      "id" $id
      "title" $post.Title
      "url" $post.RelPermalink
      "day" $day
      "date" ($post.Date.Format "2006-01-02")
      "summary" $summary
      "topic" $topic
      "categories" $categories
      "importance" 1
    -}}

    {{- $scratch.Set "nodes" (append $node ($scratch.Get "nodes")) -}}
    {{- $scratch.Set "pages" (append $post ($scratch.Get "pages")) -}}
    {{- $scratch.SetInMap "nodeById" $id $node -}}

    {{- $normPermalinkRaw := partial "java_graph/normalize_link.html" (dict "link" $post.RelPermalink) -}}
    {{- $normPermalink := trim (printf "%s" $normPermalinkRaw) " " -}}
    {{- if gt (len $normPermalink) 0 -}}
      {{- $scratch.SetInMap "urlToId" $normPermalink $id -}}

      {{- $dayAlias := replaceRE `/day-([0-9]+)$` "/day$1" $normPermalink -}}
      {{- if ne $dayAlias $normPermalink -}}
        {{- $scratch.SetInMap "urlToId" $dayAlias $id -}}
      {{- end -}}

      {{- if hasPrefix $normPermalink "/posts/" -}}
        {{- $noPosts := replaceRE `^/posts` "" $normPermalink -}}
        {{- if ne $noPosts "" -}}
          {{- $scratch.SetInMap "urlToId" $noPosts $id -}}
        {{- end -}}
      {{- else -}}
        {{- $withPosts := printf "/posts%s" $normPermalink -}}
        {{- $scratch.SetInMap "urlToId" $withPosts $id -}}
      {{- end -}}
    {{- end -}}

    {{- with $post.Params.slug -}}
      {{- $normSlugRaw := partial "java_graph/normalize_link.html" (dict "link" .) -}}
      {{- $normSlug := trim (printf "%s" $normSlugRaw) " " -}}
      {{- if gt (len $normSlug) 0 -}}
        {{- $scratch.SetInMap "urlToId" $normSlug $id -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
{{- end -}}

{{- $sortedNodes := sort ($scratch.Get "nodes") "day" "asc" -}}
{{- range $node := $sortedNodes -}}
  {{- $day := int (default 0 (index $node "day")) -}}
  {{- if gt $day 0 -}}
    {{- $dayKey := printf "%d" $day -}}
    {{- if not (index ($scratch.Get "dayToId") $dayKey) -}}
      {{- $scratch.SetInMap "dayToId" $dayKey (index $node "id") -}}
    {{- end -}}
  {{- end -}}
{{- end -}}

{{- range $day := seq 1 130 -}}
  {{- $source := index ($scratch.Get "dayToId") (printf "%d" $day) -}}
  {{- $target := index ($scratch.Get "dayToId") (printf "%d" (add $day 1)) -}}
  {{- if and $source $target -}}
    {{- partial "java_graph/add_edge.html" (dict "scratch" $scratch "source" $source "target" $target "type" "sequence" "weight" 1.3 "label" "Day progression") -}}
  {{- end -}}
{{- end -}}

{{- range $node := $sortedNodes -}}
  {{- $topic := trim (printf "%v" (index $node "topic")) " " -}}
  {{- if ne $topic "" -}}
    {{- $topicKey := lower (anchorize $topic) -}}
    {{- $previousID := index ($scratch.Get "topicLast") $topicKey -}}
    {{- if and $previousID (ne $previousID (index $node "id")) -}}
      {{- partial "java_graph/add_edge.html" (dict "scratch" $scratch "source" $previousID "target" (index $node "id") "type" "topic" "weight" 0.8 "label" "Shared topic") -}}
    {{- end -}}
    {{- $scratch.SetInMap "topicLast" $topicKey (index $node "id") -}}
  {{- end -}}
{{- end -}}

{{- $pages := $scratch.Get "pages" -}}
{{- range $post := $pages -}}
  {{- $sourceIDRaw := partial "java_graph/node_id.html" (dict "page" $post) -}}
  {{- $sourceID := trim (printf "%s" $sourceIDRaw) " " -}}
  {{- $rawLinks := findRE `\]\(([^)\s]+)` $post.RawContent -}}
  {{- range $linkMatch := $rawLinks -}}
    {{- $rawLink := replaceRE `^\]\(` "" $linkMatch -}}
    {{- $normalizedLinkRaw := partial "java_graph/normalize_link.html" (dict "link" $rawLink) -}}
    {{- $normalizedLink := trim (printf "%s" $normalizedLinkRaw) " " -}}
    {{- if gt (len $normalizedLink) 0 -}}
      {{- $resolved := $normalizedLink -}}
      {{- with index ($scratch.Get "aliasMap") $resolved -}}
        {{- $resolved = . -}}
      {{- end -}}
      {{- with index ($scratch.Get "aliasMap") $resolved -}}
        {{- $resolved = . -}}
      {{- end -}}
      {{- $targetID := index ($scratch.Get "urlToId") $resolved -}}
      {{- if and $targetID (ne $targetID $sourceID) -}}
        {{- partial "java_graph/add_edge.html" (dict "scratch" $scratch "source" $sourceID "target" $targetID "type" "reference" "weight" 1.0 "label" "References") -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
{{- end -}}

{{- with $overrides.addEdges -}}
  {{- range . -}}
    {{- $source := trim (printf "%v" .source) " " -}}
    {{- $target := trim (printf "%v" .target) " " -}}
    {{- $type := trim (printf "%v" .type) " " -}}
    {{- if and (index ($scratch.Get "nodeById") $source) (index ($scratch.Get "nodeById") $target) (ne $type "") -}}
      {{- partial "java_graph/add_edge.html" (dict "scratch" $scratch "source" $source "target" $target "type" $type "weight" (default 1.0 .weight) "label" (default $type .label) "ignoreRemove" true) -}}
    {{- end -}}
  {{- end -}}
{{- end -}}

{{- $finalNodes := slice -}}
{{- range $node := $sortedNodes -}}
  {{- $id := index $node "id" -}}
  {{- $degree := int (default 0 (index ($scratch.Get "degree") $id)) -}}
  {{- $importance := add 1 (div $degree 2) -}}
  {{- if lt $importance 1 -}}
    {{- $importance = 1 -}}
  {{- end -}}
  {{- if gt $importance 10 -}}
    {{- $importance = 10 -}}
  {{- end -}}
  {{- $nodeWithImportance := dict
    "id" (index $node "id")
    "title" (index $node "title")
    "url" (index $node "url")
    "day" (index $node "day")
    "date" (index $node "date")
    "summary" (index $node "summary")
    "topic" (index $node "topic")
    "categories" (index $node "categories")
    "importance" $importance
  -}}
  {{- $finalNodes = append $nodeWithImportance $finalNodes -}}

  {{- $topic := index $nodeWithImportance "topic" -}}
  {{- $topicCount := int (default 0 (index ($scratch.Get "topicCounts") $topic)) -}}
  {{- $scratch.SetInMap "topicCounts" $topic (add $topicCount 1) -}}
{{- end -}}

{{- $meta := dict
  "version" "v1"
  "generatedAt" (now.Format "2006-01-02T15:04:05Z07:00")
  "nodeCount" (len $finalNodes)
  "edgeCount" (len ($scratch.Get "edges"))
  "topicStats" ($scratch.Get "topicCounts")
-}}

{{- dict "meta" $meta "nodes" $finalNodes "edges" ($scratch.Get "edges") | jsonify -}}
